# Workspace MCP server credentials.
#
# HOW TO USE
#   1. .env is created from this file on bootstrap (and is git-ignored).
#   2. Paste each secret value to the RIGHT of the `=` on its line below.
#      Example:  JIRA_PERSONAL_TOKEN=ABCdef1234...
#      Do NOT change the variable name on the LEFT of the `=`.
#   3. Restart Claude Code so the MCP servers pick up the new values.
#
# NEVER commit .env.

# --- GitHub ---
# GitHub Personal Access Token — generate at https://github.com/settings/tokens?type=beta (fine-grained, scopes: repo, workflow, read:org)
GITHUB_TOKEN=

# --- Automation (STORY-0023, ADR-0010) ---
# Stage automation config for the runner watch loop.
# These values are rendered from workspace-profile.yaml automation: section.
# Do not hard-code tracker or status values in runner scripts — change them here.
#
# Tracker backend: specs (local specs/ files) | gitlab | jira
TRACKER_TYPE=specs

# Seconds between tracker polls (default: 300 = 5 minutes)
POLL_INTERVAL=300

# Opt-in label — only tickets carrying this label are dispatched.
# Set to empty string to disable the label gate.
TRACKER_REQUIRE_LABEL=adlc-auto

# Development stage entry status — tickets at this status + the label above
# + a known-agent assignee are picked up by the watch loop (ADR-0010 §3).
TRACKER_READY_STATUS=Sprint Ready

# --- Canonical status names (ADR-0010 §1) ---
# Override these to match your tracker's exact status labels.
STATUS_NEW=New
STATUS_TRIAGE=Triage
STATUS_BA_REVIEW=BA Review
STATUS_SPRINT_READY=Sprint Ready
STATUS_IN_PROGRESS=In Progress
STATUS_IN_REVIEW=In Review
STATUS_QA_READY=QA Ready
STATUS_QA_IN_PROGRESS=QA In Progress
STATUS_UAT=UAT
STATUS_READY_FOR_DEPLOY=Ready for Deploy
STATUS_DONE=Done
STATUS_DISCARDED=Discarded
