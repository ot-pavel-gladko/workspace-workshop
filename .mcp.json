{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-c",
        "set -a; source .env 2>/dev/null; set +a; export GITHUB_PERSONAL_ACCESS_TOKEN=\"${GITHUB_TOKEN}\"; exec npx -y @modelcontextprotocol/server-github"
      ],
      "env": {}
    },
    "atlassian-da-jira": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-atlassian", "--env-file", ".env"],
      "env": {
        "JIRA_URL": "https://support.dataart.com",
        "JIRA_SSL_VERIFY": "false"
      }
    }
  }
}
