{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git clone *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(python3 -m venv *)",
      "Bash(pip install *)",
      "Bash(source *)",
      "Bash(ls *)",
      "Bash(test *)",
      "Bash(python3 workspace.py *)",
      "Bash(python3 -m artisyn_skill_sdk.*)",
      "Bash(artisyn-workspace *)",
      "Bash(artisyn-meta *)"
    ],
    "deny": []
  },
  "fallbackModel": [
    "claude-sonnet-4-5"
  ],
  "requiredMinimumVersion": "2.1.175",
  "enforceAvailableModels": true,
  "extraKnownMarketplaces": {
    "artisyn": {
      "source": {
        "source": "directory",
        "path": "./artisyn-marketplace"
      }
    }
  },
  "enabledPlugins": {
    "artisyn-workspace@artisyn": true
  }
}
