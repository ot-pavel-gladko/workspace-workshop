# artisyn-workspace-runner — runtime configuration (copy to runner/.env).
# runner/.env is gitignored; NEVER commit this file with real tokens.
#
# This file configures the Docker runner that powers /artisyn-workspace:run.
# All fields are optional overrides except the auth tokens and TARGET_REPO_URL.

# --- Claude auth (pick ONE) ---
# Preferred: long-lived subscription OAuth token. Generate it once on the HOST:
#     claude setup-token
# (this is the activation-URL + paste-back-code flow), then paste it here.
CLAUDE_CODE_OAUTH_TOKEN=

# Fallback: Anthropic Console API key (per-token billing instead of subscription).
# ANTHROPIC_API_KEY=

# --- Code repositories (auto-discovered from the sibling ../src tree) ---
# By default the runner scans EVERY folder under your workspace's sibling
# ../src directory (bind-mounted read-only) and prepares each one:
#   * git repo    -> cloned FRESH into /artisyn/code-repo/<name>, checked out at
#                    that repo's OWN current branch; `git push` auto-opens an MR
#                    against that branch (one MR per repo).
#   * non-git     -> copied READ-ONLY to /artisyn/code-readonly/<name> as
#                    reference material (never pushed).
# Your host working copies are never touched — clones are fresh from origin.
# No per-repo config needed: remote URL and base branch are read from each
# folder's own .git. Auth uses your host SSH identity (see Git auth below).

# --- Single-repo fallback (OPTIONAL) ---
# Used ONLY if ../src resolves to zero folders. Point at one HTTPS/SSH repo.
# TARGET_REPO_URL=
# Base/MR-target branch for the fallback clone, and for any detached src repo
# (default: main). The src-scan path detects per-repo branches automatically.
# TARGET_BASE_BRANCH=main

# --- Git auth ---
# Primary (default): your host ~/.ssh is bind-mounted read-only into the
# container, so SSH remotes (git@gitlab.../...) authenticate with your existing
# keys + config. Host keys are scanned automatically. Nothing to set here.
#
# Fallback: a GitLab/GitHub PAT (read_repository + write_repository) used ONLY
# for HTTPS remotes; injected into the HTTPS clone URL inside the named volume.
# `docker compose down -v` wipes the volume and the token.
# GIT_TOKEN=

# Git identity for commits made inside the container.
# GIT_AUTHOR_NAME=Artisyn Agent
# GIT_AUTHOR_EMAIL=artisyn.agent@dataart.com

# --- Permission mode ---
# acceptEdits (default) honours settings.json allow/deny; bypassPermissions
# runs fully unattended (use only when host mounts are restricted to this runner).
# CLAUDE_PERMISSION_MODE=acceptEdits

# --- Output and verbosity ---
# OUTPUT_FORMAT=text          # text | json | stream-json
# RUNNER_VERBOSE=1            # 1 = stream turn-by-turn processing; 0 = final result only

# --- Dry run ---
# RUNNER_DRYRUN=0             # 1 = list agents and exit (no token, no dispatch)

# ---------------------------------------------------------------------------
# Watch mode (--watch / artisyn-watch service) — STORY-0007b
# Polls the tracker for issues that are BOTH labeled TRACKER_READY_LABEL AND
# assigned to TRACKER_ASSIGNEE_ID (the two-condition HITL authorization gate).
# ---------------------------------------------------------------------------

# Tracker backend: "gitlab" is the only built implementation.
# TRACKER_TYPE=gitlab

# GitLab base URL.
# GITLAB_URL=https://gitlab.dataart.com

# GitLab project numeric ID or URL-encoded path (e.g. 123 or my-group%2Fmy-repo).
# REQUIRED for watch mode.
GITLAB_PROJECT_ID=

# GitLab label that marks a ticket as ready for autonomous dispatch.
# The dispatched lead is expected to remove this label on pickup (natural dequeue).
# TRACKER_READY_LABEL=ready-for-agent

# GitLab user ID of the runner's own account (HITL gate).
# Only issues assigned to this account AND labeled ready are dispatched.
# Find your user ID at: Settings > Profile (GitLab) or via the API:
#   curl -H "PRIVATE-TOKEN: <your-token>" https://gitlab.dataart.com/api/v4/user | python3 -m json.tool | grep '"id"'
# REQUIRED for watch mode.
TRACKER_ASSIGNEE_ID=

# Scoped GitLab token for the REST poll (api or read_api scope).
# Passed via PRIVATE-TOKEN HTTP header — never baked into a URL or log.
# REQUIRED for watch mode.
GITLAB_TOKEN=

# Poll interval in seconds (default: 300 = 5 minutes).
# POLL_INTERVAL=300

# Maximum issues fetched per poll.
# TRACKER_MAX_RESULTS=50

# Printf template for the dispatch prompt sent to the lead (%s = issue IID).
# TRACKER_DISPATCH_TEMPLATE=dispatch issue #%s

# ---------------------------------------------------------------------------
# UI sidecar (--ui / compose profile "ui") — STORY-0008, ADR-0004
#
# The UI sidecar is OPTIONAL.  The headless artisyn-lead and artisyn-watch
# services run WITHOUT it and take no dependency on it (AC6).
#
# Enable: docker compose --profile ui up -d
#   Chainlit chat:        http://localhost:8000  (or UI_PORT below)
#   Langfuse dashboard:   http://localhost:3000  (or LANGFUSE_PORT below)
# ---------------------------------------------------------------------------

# Port for the Chainlit browser chat (default: 8000).
# UI_PORT=8000

# Port for the self-hosted Langfuse traces dashboard (default: 3000).
# LANGFUSE_PORT=3000

# Langfuse credentials — used by artisyn-ui to send traces to artisyn-langfuse.
# After starting the UI sidecar, log in to http://localhost:3000, create a
# project, and copy the public + secret keys here.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse server URL as seen by the artisyn-ui container.
# Default (internal docker network): http://artisyn-langfuse:3000
# Override if Langfuse is hosted elsewhere.
# LANGFUSE_HOST=http://artisyn-langfuse:3000

# Langfuse server secrets — CHANGE THESE for any non-local deployment.
# Dev-only defaults are set in docker-compose.yml; override here for production.
# NEXTAUTH_SECRET=<random-string>
# LANGFUSE_SALT=<random-string>

# adlc cockpit URL (OpenObserve dashboard) — surfaced as a link in the chat
# welcome and alongside Langfuse traces (AC4: surfacing, not reimplementing).
# Set to your adlc/OpenObserve dashboard URL.
# ADLC_COCKPIT_URL=

# --- Specs tracker backend (TRACKER_TYPE=specs) ---------------------------
# Auto-dispatch local specs/ stories instead of polling GitLab. A story is
# dispatched only when ALL hold (ADR-0010 §3):
#   1. Status == TRACKER_READY_STATUS (the Development stage entry status)
#   2. Assignee names a known generated agent
#   3. (when TRACKER_REQUIRE_LABEL is set) the story's Labels: field contains it
#
# TRACKER_TYPE=specs
# SPECS_STORIES_DIR=specs/STORIES
# SPECS_AGENTS_DIR=.claude/agents
#
# Development stage entry status — tickets at this status are candidates.
# Default matches the ADR-0010 cg canonical workflow. Override to match your
# tracker's exact label (case-sensitive).
# TRACKER_READY_STATUS=Sprint Ready
#
# Opt-in label gate (ADR-0010 §3, STORY-0025): only stories carrying this label
# are dispatched. Set to empty string to disable the label gate entirely.
# TRACKER_REQUIRE_LABEL=adlc-auto
#
# Dequeue state file — records content hashes of dispatched stories so an
# unchanged already-dispatched story is not re-dispatched across container restarts.
# SPECS_STATE_FILE=/artisyn/state/dispatched.json
#
# Per-dispatch KPI ledger (STORY-0027): JSONL file, one record per dispatch.
# Each record: {"timestamp":..., "story_key":..., "stage":..., "cost_usd":..., "tokens":...}
# SPECS_LEDGER_FILE=/artisyn/state/dispatch-ledger.jsonl
#
# Dry-run dispatch (e2e/testing): validate the detect→dispatch loop WITHOUT
# firing a real claude session. The watcher logs "[DRYRUN]" and the dispatch
# prompt but does not invoke the lead agent. Passed via this env_file (not the
# compose `environment` block) so it overrides cleanly.
# RUNNER_DISPATCH_DRYRUN=1

# ---------------------------------------------------------------------------
# Stage automation config (STORY-0023, ADR-0010)
#
# These vars are rendered from workspace-profile.yaml automation: section by
# `workspace.py generate` (via the workspace .env.example).  Edit them in
# workspace-profile.yaml, not here — regenerating the workspace overwrites the
# workspace .env.example with the correct values from automation: config.
#
# TRACKER_REQUIRE_LABEL   — opt-in label gate; only tickets carrying this label
#                            are dispatched (automation.require_label in profile).
#                            Set to empty to disable the label gate.
# TRACKER_READY_STATUS    — Development stage entry status
#                            (automation.stages.development.entry_status in profile).
#                            The watch loop picks up tickets at this status.
#
# Canonical status name vars (ADR-0010 §1) — values come from the profile's
# automation.statuses.*  keys; override them in workspace-profile.yaml to match
# your tracker's exact labels.  Env var names:
# STATUS_NEW, STATUS_TRIAGE, STATUS_BA_REVIEW, STATUS_SPRINT_READY,
# STATUS_IN_PROGRESS, STATUS_IN_REVIEW, STATUS_QA_READY, STATUS_QA_IN_PROGRESS,
# STATUS_UAT, STATUS_READY_FOR_DEPLOY, STATUS_DONE, STATUS_DISCARDED
# ---------------------------------------------------------------------------
